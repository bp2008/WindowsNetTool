<Project Sdk="Microsoft.NET.Sdk">

	<PropertyGroup>
		<OutputType>WinExe</OutputType>
		<TargetFramework>net48</TargetFramework>
		<UseWindowsForms>true</UseWindowsForms>
		<LangVersion>8.0</LangVersion>
		<RootNamespace>WindowsNetTool</RootNamespace>
		<AssemblyName>WindowsNetTool</AssemblyName>
		<ApplicationManifest>app.manifest</ApplicationManifest>
		<Version>1.1.0</Version>
		<Product>WindowsNetTool</Product>
		<Description>A collection of Windows networking utilities.</Description>
		<Copyright>Copyright © 2026</Copyright>
		<AssemblyVersion>1.1.0</AssemblyVersion>
		<FileVersion>1.1.0</FileVersion>
	</PropertyGroup>

	<ItemGroup>
		<!-- Required for `dynamic` COM interop with Shell.Application (opening native connection dialogs). -->
		<Reference Include="Microsoft.CSharp" />
	</ItemGroup>

</Project>
